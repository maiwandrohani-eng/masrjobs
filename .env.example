# Database (Neon)
DATABASE_URL=""

# NextAuth (set strong secret in production; Vercel: 32+ random bytes)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Public site URL for canonicals, OG URLs, sitemap
NEXT_PUBLIC_SITE_URL="https://masrjobs.org"

# Only "true" for local preview / UX testing — keep false in production
NEXT_PUBLIC_ENABLE_DEMO_AUTH="false"

# Transactional email (Resend — https://resend.com). RESEND_API_KEY required to send.
# RESEND_API_KEY=""
# Default from-address if unset: MasrJobs <noreply@masrjobs.org>
# EMAIL_FROM="MasrJobs <noreply@masrjobs.org>"
# Contact form: receives copies of /contact submissions (must be a real inbox you monitor).
# CONTACT_INBOX_EMAIL="maiwandr@gmail.com"
