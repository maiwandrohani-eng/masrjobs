// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  INDIVIDUAL
  ORG_USER
  ADMIN
}

enum OrgVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OpportunityStatus {
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
  CLOSED
}

enum WorkArrangement {
  ONSITE
  HYBRID
  REMOTE
}

enum CompensationType {
  PAID
  UNPAID
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  REJECTED
  ACCEPTED
}

enum OpportunityApplyMode {
  INTERNAL
  APPLY_BY_EMAIL
  EXTERNAL_LINK
}

enum ExternalApplyChannel {
  EMAIL
  EXTERNAL_LINK
}

enum AdminActionType {
  USER_CREATED
  USER_UPDATED
  USER_DISABLED
  USER_REACTIVATED
  USER_DELETED
  ORG_APPROVED
  ORG_REJECTED
  ORGANIZATION_DEACTIVATED
  ORGANIZATION_REACTIVATED
  ORGANIZATION_DELETED
  OPPORTUNITY_APPROVED
  OPPORTUNITY_REJECTED
  OPPORTUNITY_EDITED
  OPPORTUNITY_REMOVED
  OPPORTUNITY_DELETED
  ORG_PROFILE_CHANGE_APPROVED
  ORG_PROFILE_CHANGE_REJECTED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  FEATURED_UPDATED
  CONTENT_REPORTED
  CONTENT_MODERATED
  REPORT_EXPORTED
}

enum OrgProfileChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(INDIVIDUAL)

  firstName String?
  lastName  String?
  phone     String?
  location  String?
  bio       String?

  // CV upload metadata (stored as a file path/url in this MVP)
  cvFileName String?
  cvFileUrl  String?
  linkedinUrl  String?
  portfolioUrl String?

  // Organization linkage for ORG_USER
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  applications  Application[]
  saved         SavedOpportunity[]
  notifications Notification[]
  auditActions  AdminActionLog[]   @relation("AdminActor")

  passwordResetTokens PasswordResetToken[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([organizationId])
}

model Organization {
  id                 String                @id @default(cuid())
  name               String
  slug               String                @unique
  email              String?
  phone              String?
  website            String?
  location           String?
  description        String?
  logoUrl            String?
  featuredBadge      Boolean               @default(false)
  profileCompleteness Int                  @default(0)
  verificationStatus OrgVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  /** When false, the org is hidden from the public directory and cannot post. */
  isActive           Boolean               @default(true)

  users         User[]
  opportunities Opportunity[]
  notifications Notification[]
  profileChanges OrganizationProfileChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** Employer-proposed organization directory / contact updates; applied after admin approval. */
model OrganizationProfileChange {
  id             String @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  status OrgProfileChangeStatus @default(PENDING)

  submittedByUserId String?

  proposedName        String
  proposedEmail       String?
  proposedPhone       String?
  proposedWebsite     String?
  proposedLocation    String?
  proposedDescription String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([organizationId, status])
}

model Category {
  id          String  @id @default(cuid())
  nameEn      String
  nameAr      String?
  slug        String  @unique
  description String?

  opportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Opportunity {
  id String @id @default(cuid())

  /** Optional public slug for SEO URLs; falls back to `id` when absent. */
  slug String? @unique

  title            String
  description      String
  requirements     String?
  howToApply       String?
  externalApplyUrl String?

  applyMode                OpportunityApplyMode @default(INTERNAL)
  applicationEmail       String?
  externalApplicationUrl String?

  location        String?
  deadline        DateTime?
  type            String // e.g. full-time, part-time, consultancy, training, volunteer, tender, grant
  workArrangement WorkArrangement  @default(ONSITE)
  compensation    CompensationType @default(PAID)

  status      OpportunityStatus @default(PENDING_APPROVAL)
  publishedAt DateTime?
  closedAt    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  attachments  OpportunityAttachment[]
  applications Application[]
  savedBy      SavedOpportunity[]
  featured     FeaturedOpportunity?
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, deadline])
  @@index([organizationId])
  @@index([categoryId])
}

model OpportunityAttachment {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  fileName String
  fileUrl  String

  createdAt DateTime @default(now())

  @@index([opportunityId])
}

model Application {
  id String @id @default(cuid())

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status      ApplicationStatus @default(SUBMITTED)
  coverLetter String?

  applicantFullName String?
  applicantPhone    String?
  linkedinUrl       String?
  portfolioUrl      String?
  cvUrl             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([opportunityId, userId])
  @@index([userId, status])
  @@index([opportunityId, status])
}

model SavedOpportunity {
  id String @id @default(cuid())

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([opportunityId, userId])
  @@index([userId])
}

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  opportunityId String?
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  title   String
  message String
  href    String?
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([organizationId])
  @@index([opportunityId])
}

model FeaturedOpportunity {
  id String @id @default(cuid())

  opportunityId String      @unique
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  rank      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([rank])
}

model ExternalApplyIntent {
  id String @id @default(cuid())

  listingId      String
  applicantEmail String
  channel        ExternalApplyChannel

  createdAt DateTime @default(now())

  @@unique([listingId, applicantEmail, channel])
  @@index([listingId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AdminActionLog {
  id String @id @default(cuid())

  action      AdminActionType
  actorUserId String?
  actorUser   User?           @relation("AdminActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  targetType String?
  targetId   String?
  meta       Json?

  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
}

/** Public newsletter signups from the site (e.g. Resources page). */
model NewsletterSubscription {
  id     String @id @default(cuid())
  email  String @unique
  source String?

  createdAt DateTime @default(now())

  @@index([createdAt])
}

/** Homepage early-launch notify list (shown when published opportunity count is under 10). */
model EarlyAccessEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/** Community events calendar (public events page). */
model CommunityEvent {
  id        String   @id @default(cuid())
  eventDate String
  title     String
  detail    String   @db.Text
  href      String?
  confirmed Boolean  @default(false)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder, eventDate])
}

/** Key-value settings editable from admin (e.g. public contact card). */
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
